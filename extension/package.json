{
  "name": "mind-language",
  "displayName": "Mind Language — 自然语言语义标注",
  "description": "为 .mind 文件提供完整的语言支持：语义高亮、缩进关系线、实体关联悬停、逻辑诊断。支持 C/Python/自然语言混合语法。",
  "version": "1.0.0",
  "publisher": "mind-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TianQue6916/Structured-Pseudocode.git"
  },
  "private": true,
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "mind",
    "semantic",
    "annotation",
    "natural-language",
    "reasonix"
  ],
  "activationEvents": [
    "onLanguage:mind"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.82.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "mind",
        "aliases": [
          "Mind",
          "mind"
        ],
        "extensions": [
          ".mind"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mind",
        "scopeName": "source.mind",
        "path": "./syntaxes/mind.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Mind Language",
      "properties": {
        "mind.actionColor": {
          "type": "string",
          "default": "#569CD6",
          "format": "color",
          "description": "操作词颜色（控制流关键字: if/else/while/for 等）"
        },
        "mind.entityColor": {
          "type": "string",
          "default": "#9CDCFE",
          "format": "color",
          "description": "实体/变量颜色（变量引用、名词）"
        },
        "mind.functionColor": {
          "type": "string",
          "default": "#4EC9B0",
          "format": "color",
          "description": "函数调用颜色（C/Python 函数调用）"
        },
        "mind.typeColor": {
          "type": "string",
          "default": "#4FC1FF",
          "format": "color",
          "description": "类型关键字颜色（int/float/void/struct 等）"
        },
        "mind.numberColor": {
          "type": "string",
          "default": "#B5CEA8",
          "format": "color",
          "description": "数字/常量颜色"
        },
        "mind.stringColor": {
          "type": "string",
          "default": "#CE9178",
          "format": "color",
          "description": "字符串颜色"
        },
        "mind.naturalColor": {
          "type": "string",
          "default": "#CE9178",
          "format": "color",
          "description": "自然语言描述颜色"
        },
        "mind.commentColor": {
          "type": "string",
          "default": "#6A9955",
          "format": "color",
          "description": "注释颜色"
        },
        "mind.operatorColor": {
          "type": "string",
          "default": "#D4D4D4",
          "format": "color",
          "description": "运算符颜色"
        },
        "mind.errorColor": {
          "type": "string",
          "default": "#F44747",
          "format": "color",
          "description": "逻辑错误下划线颜色"
        },
        "mind.warningColor": {
          "type": "string",
          "default": "#6A9955",
          "format": "color",
          "description": "不理解/警告下划线颜色"
        },
        "mind.indentColors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#3A3D41",
            "#4A4D51",
            "#5A5D61",
            "#6A6D71",
            "#7A7D81"
          ],
          "description": "缩进线颜色列表（按层级，第1层索引0，第2层索引1，以此类推）"
        },
        "mind.enableIndentLines": {
          "type": "boolean",
          "default": true,
          "description": "是否显示缩进关系线"
        },
        "mind.enableHoverHighlight": {
          "type": "boolean",
          "default": true,
          "description": "是否启用悬停引用高亮（悬停实体时灰色高亮所有同义词）"
        },
        "mind.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "是否启用逻辑错误诊断（红色=错误，绿色=不理解）"
        },
        "mind.analysisDebounce": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "分析防抖时间（毫秒）。修改文本后等待多久触发分析。"
        },
        "mind.bridgePort": {
          "type": "number",
          "default": 3456,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Mind Bridge 桥接服务端口号"
        },
        "mind.bridgeHost": {
          "type": "string",
          "default": "localhost",
          "description": "Mind Bridge 桥接服务主机地址"
        }
      }
    },
    "commands": [
      {
        "command": "mind.analyzeNow",
        "title": "Mind: 立即分析当前文件"
      },
      {
        "command": "mind.restartBridge",
        "title": "Mind: 重新连接桥接服务"
      },
      {
        "command": "mind.showStatus",
        "title": "Mind: 显示分析状态"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mind.analyzeNow",
          "when": "editorLangId == mind",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mind.analyzeNow",
          "when": "editorLangId == mind"
        }
      ]
    }
  }
}
