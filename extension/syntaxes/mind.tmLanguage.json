{
  "scopeName": "source.mind",
  "name": "Mind",
  "fileTypes": [".mind"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-calls" },
    { "include": "#function-defs" },
    { "include": "#decorators" },
    { "include": "#annotations" },
    { "include": "#operators" },
    { "include": "#chinese" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.mind", "match": "#.*$" },
        { "name": "comment.line.double-slash.mind", "match": "\\/\\/.*$" },
        { "name": "comment.block.mind", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.mind", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single.mind", "begin": "'", "end": "'" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.mind", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.float.mind", "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b" },
        { "name": "constant.numeric.integer.mind", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords": {
      "name": "keyword.control.mind",
      "match": "\\b(if|else|elif|while|for|switch|case|default|break|continue|return|goto|do|import|from|as|export|include|require|try|except|finally|raise|pass|yield|lambda|with|assert|del|global|nonlocal|async|await|and|or|not|in|is)\\b"
    },
    "declarations": {
      "name": "keyword.declaration.mind",
      "match": "\\b(def|class|struct|enum|union|typedef|interface|fun|fn|function|let|var|const|val|mut|static|extern|register|volatile|inline|sizeof|signed|unsigned|self|cls)\\b"
    },
    "builtins": {
      "name": "support.function.builtin.mind",
      "match": "\\b(print|len|range|min|max|sum|abs|round|sorted|reversed|enumerate|zip|map|filter|open|read|write|append|pop|push|peek|update|delete|insert|remove|clear|copy|count|index|extend|sort|reverse|find|replace|split|join|strip|format|input|type|super|isinstance|hasattr|getattr|setattr)\\b"
    },
    "types": {
      "name": "storage.type.mind",
      "match": "\\b(int|float|double|char|bool|void|short|long|size_t|string|auto|nullptr_t|wchar_t|FILE|pid_t|null|None|True|False|true|false)\\b"
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.mind", "match": "\\b(PI|E|NULL|nullptr|EOF|INT_MAX|INT_MIN|INFINITY|NAN)\\b" }
      ]
    },
    "function-calls": {
      "name": "entity.name.function.call.mind",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": { "1": { "name": "entity.name.function.mind" } }
    },
    "function-defs": {
      "match": "\\b(def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.mind" },
        "2": { "name": "entity.name.function.definition.mind" }
      }
    },
    "decorators": {
      "name": "entity.name.function.decorator.mind",
      "match": "(@[a-zA-Z_][a-zA-Z0-9_.]*)"
    },
    "annotations": {
      "name": "storage.type.annotation.mind",
      "match": "(:\\s*)(int|float|str|bool|None|List|Dict|Set|Tuple|Optional|Any|Union|void|char|double|long|short|struct|enum)"
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.mind", "match": "===|!==|==|!=|>=|<=|>|<|≤|≥|≠|≡" },
        { "name": "keyword.operator.arithmetic.mind", "match": "\\+\\+|--|\\+=|-=|\\*=|/=|%=|\\+|-|\\*|/|%" },
        { "name": "keyword.operator.assignment.mind", "match": ":=|->|←|→|=>" },
        { "name": "keyword.operator.logical.mind", "match": "&&|\\|\\||!" }
      ]
    },
    "chinese": {
      "name": "markup.other.mind",
      "match": "[\\u4e00-\\u9fff\\u3000-\\u303f]+"
    },
    "identifiers": {
      "name": "variable.other.mind",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
